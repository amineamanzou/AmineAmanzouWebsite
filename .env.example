# Browser RUM is off unless every value below is set explicitly at build time.
PUBLIC_BROWSER_OBSERVABILITY_ENABLED=false
PUBLIC_BROWSER_OBSERVABILITY_URL=
# Public, non-authenticating browser value. Never put a ClickStack server key here.
PUBLIC_BROWSER_OBSERVABILITY_API_KEY=
PUBLIC_BROWSER_SERVICE_NAME=amineamanzou-frontend
PUBLIC_BROWSER_SERVICE_VERSION=local
PUBLIC_BROWSER_SITE_NAME=amineamanzou.fr
PUBLIC_DEPLOYMENT_ENVIRONMENT=production
