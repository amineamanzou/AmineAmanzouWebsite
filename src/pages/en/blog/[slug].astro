---
import { getCollection } from "astro:content";
import ArticlePage from "../../../components/ArticlePage.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const englishArticles = articles.filter((article) => article.data.locale === "en");

  return englishArticles.map((article) => {
    const frenchPeer = articles.find(
      (candidate) =>
        candidate.data.locale === "fr" &&
        candidate.data.translationKey === article.data.translationKey,
    );

    return {
      params: { slug: article.data.articleSlug },
      props: {
        article,
        alternates: [
          ...(frenchPeer
            ? [{ locale: "fr" as const, path: `/blog/${frenchPeer.data.articleSlug}/` }]
            : []),
          { locale: "en", path: `/en/blog/${article.data.articleSlug}/` },
        ],
        alternateHref: frenchPeer ? `/blog/${frenchPeer.data.articleSlug}/` : "/blog/",
      },
    };
  });
}

const { article, alternateHref, alternates } = Astro.props;
const articleAlternates = alternates as Array<{ locale: "fr" | "en"; path: string }>;
---

<ArticlePage article={article} alternateHref={alternateHref} alternates={articleAlternates} />
