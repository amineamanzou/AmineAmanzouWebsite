---
import SiteFooter from "../../components/SiteFooter.astro";
import Topbar from "../../components/Topbar.astro";
import { profile } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Amine Amanzou"
  description="Contacter Amine Amanzou pour une mission SRE, observabilité, cloud ou DevOps."
  path="/contact/"
  bodyClass="contact-page"
>
  <Topbar currentPath="/contact/" />

  <main class="page-main">
    <section class="contact-hero section-shell">
      <div>
        <p class="role-line">{profile.role}</p>
        <h1>Parlons fiabilité, observabilité et production.</h1>
        <p>
          Pour une mission, une qualification technique ou un échange autour d'un
          sujet SRE, le plus simple est de m'écrire directement.
        </p>
      </div>
      <div class="contact-panel">
        <a class="mail-link" href="mailto:amineamanzou@gmail.com">{profile.email}</a>
        <span>{profile.location}</span>
        <div class="social-list">
          {profile.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
