---
import "../styles/global.css";
import { canonical, type JsonLd } from "../data/seo";
import type { Locale } from "../data/site";
import type { AnalyticsPageType } from "../lib/analytics/events";

type Props = {
  title: string;
  description: string;
  path?: string;
  canonicalPath?: string;
  alternates?: Array<{ locale: Locale; path: string }>;
  bodyClass?: string;
  noindex?: boolean;
  locale?: Locale;
  ogType?: "website" | "article";
  ogImage?: string;
  publishedAt?: string;
  modifiedAt?: string;
  jsonLd?: JsonLd;
};

const {
  title,
  description,
  path,
  canonicalPath,
  alternates = [],
  bodyClass,
  noindex = false,
  locale = "fr",
  ogType = "website",
  ogImage = "/images/amine-amanzou-profile.jpeg",
  publishedAt,
  modifiedAt,
  jsonLd,
} = Astro.props;
const currentPath = canonicalPath ?? path ?? Astro.url.pathname;
const canonicalUrl = Astro.site ? new URL(currentPath, Astro.site).toString() : canonical(currentPath);
const alternateLinks = Astro.site
  ? alternates.map((alternate) => ({
      locale: alternate.locale,
      href: new URL(alternate.path, Astro.site).toString(),
    }))
  : alternates.map((alternate) => ({
      locale: alternate.locale,
      href: canonical(alternate.path),
    }));
const xDefaultPath =
  alternates.find((alternate) => alternate.locale === "fr")?.path ?? currentPath;
const xDefaultUrl = Astro.site ? new URL(xDefaultPath, Astro.site).toString() : canonical(xDefaultPath);
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).toString() : canonical(ogImage);
const jsonLdText = jsonLd ? JSON.stringify(jsonLd).replaceAll("<", "\\u003c") : undefined;
// No-index routes in this site are immediate compatibility redirects. Starting
// a RUM session there would create a duplicate, near-empty navigation session.
const browserObservabilityEnabled = import.meta.env.PUBLIC_BROWSER_OBSERVABILITY_ENABLED === "true" && !noindex;
const BrowserObservability = browserObservabilityEnabled
  ? (await import("../components/BrowserObservability.astro")).default
  : undefined;
const productAnalyticsEnabled = import.meta.env.PUBLIC_PRODUCT_ANALYTICS_ENABLED === "true" && !noindex;
const analyticsPath = currentPath.split(/[?#]/, 1)[0].replace(/^\/en(?=\/|$)/, "") || "/";
const analyticsPageType: AnalyticsPageType = analyticsPath === "/"
  ? "home"
  : analyticsPath === "/dossier/"
    ? "dossier"
    : analyticsPath === "/contact/"
      ? "contact"
      : analyticsPath === "/blog/"
        ? "blog_index"
        : analyticsPath.startsWith("/blog/")
          ? "article"
          : ["/audit-observabilite/", "/observability-audit/", "/consultant-opentelemetry/", "/opentelemetry-consulting/", "/fractional-observability-lead/"].includes(analyticsPath)
            ? "service"
          : analyticsPath === "/privacy/"
            ? "privacy"
            : "other";
const AnalyticsConsent = productAnalyticsEnabled
  ? (await import("../components/AnalyticsConsent.astro")).default
  : undefined;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      id="site-favicon"
      rel="icon"
      type="image/png"
      href="/favicon-light.png?v=20260719"
      data-light-href="/favicon-light.png?v=20260719"
      data-dark-href="/favicon-dark.png?v=20260719"
    />
    <link rel="shortcut icon" href="/favicon.ico?v=20260719" />
    <link rel="apple-touch-icon" href="/favicon-light.png?v=20260719" />
    <script is:inline>
      (() => {
        const themeStorageKey = "amineamanzou-theme";
        const localeStorageKey = "amineamanzou-locale";
        const root = document.documentElement;
        const systemDark = window.matchMedia("(prefers-color-scheme: dark)");
        const readStorage = (key) => {
          try {
            return localStorage.getItem(key);
          } catch {
            return null;
          }
        };
        const writeStorage = (key, value) => {
          try {
            localStorage.setItem(key, value);
          } catch {
            return;
          }
        };
        const storedTheme = readStorage(themeStorageKey);
        const initialTheme = storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : systemDark.matches
            ? "dark"
            : "light";

        const syncFavicon = (theme) => {
          const favicon = document.querySelector("#site-favicon");
          if (!(favicon instanceof HTMLLinkElement)) return;

          favicon.href = theme === "dark"
            ? favicon.dataset.darkHref
            : favicon.dataset.lightHref;
        };

        root.dataset.theme = initialTheme;
        syncFavicon(initialTheme);
        document.addEventListener("site-theme-change", (event) => {
          const theme = event instanceof CustomEvent ? event.detail?.theme : undefined;
          if (theme === "light" || theme === "dark") syncFavicon(theme);
        });

        if (window.location.pathname === "/") {
          const storedLocale = readStorage(localeStorageKey);

          if (storedLocale === "en") {
            window.location.replace(`/en/${window.location.search}${window.location.hash}`);
          }
        }

        document.addEventListener("click", (event) => {
          const target = event.target;
          const link = target instanceof Element ? target.closest("[data-locale-target]") : null;
          if (!(link instanceof HTMLAnchorElement)) return;

          const targetLocale = link.dataset.localeTarget;
          if (targetLocale === "fr" || targetLocale === "en") {
            writeStorage(localeStorageKey, targetLocale);
          }
        }, true);
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map((alternate) => <link rel="alternate" hreflang={alternate.locale} href={alternate.href} />)}
    {alternateLinks.length > 0 && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Amine Amanzou" />
    <meta property="og:locale" content={locale === "fr" ? "fr_FR" : "en_US"} />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {modifiedAt && <meta property="article:modified_time" content={modifiedAt} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLdText && <script is:inline type="application/ld+json" set:html={jsonLdText} />}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
    {BrowserObservability && <BrowserObservability locale={locale} />}
    {AnalyticsConsent && <AnalyticsConsent locale={locale} pageType={analyticsPageType} />}
    <script is:inline>
      (() => {
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const revealItems = Array.from(document.querySelectorAll("[data-reveal]"));
        const metricValues = Array.from(document.querySelectorAll("[data-count-to]"));

        const formatMetric = (value, prefix, suffix) => `${prefix}${Math.round(value)}${suffix}`;

        if (reducedMotion) {
          metricValues.forEach((element) => {
            const target = Number(element.dataset.countTo || "0");
            element.textContent = formatMetric(target, element.dataset.prefix || "", element.dataset.suffix || "");
          });
          return;
        }

        document.documentElement.classList.add("motion-ready");

        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.16, rootMargin: "0px 0px -8% 0px" },
        );

        revealItems.forEach((item) => revealObserver.observe(item));

        const metricObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const element = entry.target;
              const target = Number(element.dataset.countTo || "0");
              const prefix = element.dataset.prefix || "";
              const suffix = element.dataset.suffix || "";
              const duration = 980;
              const startedAt = performance.now();

              const step = (now) => {
                const progress = Math.min((now - startedAt) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 4);
                element.textContent = formatMetric(target * eased, prefix, suffix);

                if (progress < 1) {
                  requestAnimationFrame(step);
                } else {
                  element.textContent = formatMetric(target, prefix, suffix);
                }
              };

              requestAnimationFrame(step);
              observer.unobserve(element);
            });
          },
          { threshold: 0.6 },
        );

        metricValues.forEach((metric) => metricObserver.observe(metric));
      })();
    </script>
  </body>
</html>
