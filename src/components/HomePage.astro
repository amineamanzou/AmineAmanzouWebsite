---
import { getCollection } from "astro:content";
import SiteFooter from "./SiteFooter.astro";
import Topbar from "./Topbar.astro";
import { getArticleCards } from "../data/articles";
import { downloads, home, localized, profile, experiences, type Locale } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

type Props = {
  locale?: Locale;
};

const { locale = "fr" } = Astro.props;
const copy = localized[locale];
const download = downloads[locale];
const path = locale === "fr" ? "/" : "/en/";
const dossierPath = locale === "fr" ? "/dossier/" : "/en/dossier/";
const blogPath = locale === "fr" ? "/blog/" : "/en/blog/";
const articleCards = getArticleCards(await getCollection("articles"), locale);
---

<BaseLayout
  title={copy.meta.title}
  description={copy.meta.description}
  canonicalPath={path}
  alternates={[
    { locale: "fr", path: "/" },
    { locale: "en", path: "/en/" },
  ]}
  bodyClass="home-page"
  locale={locale}
>
  <Topbar currentPath={path} locale={locale} />

  <main>
    <section class="hero section-shell">
      <div class="hero-copy" data-reveal>
        <p class="role-line">{copy.role}</p>
        <h1>{copy.hero.title}</h1>
        <p class="hero-lede">{copy.hero.body}</p>
        <p class="hero-proof">{copy.hero.proofLine}</p>
        <div class="hero-actions">
          <a class="button button-primary" href={dossierPath} data-analytics-event="site.cta_click" data-analytics-cta-id="open_dossier" data-analytics-placement="hero">{copy.hero.primaryCta}</a>
          <a class="button button-secondary" href={`mailto:${profile.email}`} data-analytics-event="site.cta_click" data-analytics-cta-id="contact_mission" data-analytics-placement="hero">{copy.hero.secondaryCta}</a>
        </div>
      </div>
      <aside class="portrait-card" aria-label={locale === "fr" ? "Profil d'Amine Amanzou" : "Amine Amanzou profile"} data-reveal>
        <img
          src={profile.portrait}
          srcset="/images/amine-amanzou-profile-480.webp 480w, /images/amine-amanzou-profile-960.webp 960w, /images/amine-amanzou-profile-1440.webp 1440w"
          sizes="(max-width: 760px) calc(100vw - 36px), (max-width: 1100px) 42vw, 600px"
          width="960"
          height="884"
          alt={locale === "fr" ? "Portrait d'Amine Amanzou" : "Portrait of Amine Amanzou"}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div>
          <strong>{profile.name}</strong>
          <span>{profile.location}</span>
        </div>
      </aside>
    </section>

    <section class="proof-band" id="preuves" aria-labelledby="proof-title">
      <div class="section-shell">
        <div class="section-heading" data-reveal>
          <h2 id="proof-title">{copy.proof.title}</h2>
          <p>{copy.proof.body}</p>
        </div>
        <div class="metric-grid">
          {home.metrics.map((metric, index) => (
            <article class="metric-card" data-reveal style={`--i: ${index}`}>
              <span>{metric.label}</span>
              <strong
                class="metric-value"
                data-count-to={metric.countTo}
                data-prefix={metric.prefix ?? ""}
                data-suffix={metric.suffix ?? ""}
              >
                {metric.value}
              </strong>
              <p>{metric.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-shell split-section">
      <div class="section-heading sticky-heading" data-reveal>
        <h2>{copy.observability.title}</h2>
        <p>{copy.observability.body}</p>
      </div>
      <div class="expertise-list">
        {home.expertise.map((item, index) => (
          <article class="expertise-card" data-reveal style={`--i: ${index}`}>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <ul>
              {item.items.map((skill) => <li>{skill}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell work-preview">
      <div class="section-heading" data-reveal>
        <h2>{copy.workPreview.title}</h2>
        <p>{copy.workPreview.body}</p>
      </div>
      <div class="preview-timeline">
        {experiences.slice(0, 3).map((experience, index) => (
          <article data-reveal style={`--i: ${index}`}>
            <span>{experience.period}</span>
            <h3>{experience.role}</h3>
            <strong>{experience.company}</strong>
            <p>{experience.summary}</p>
          </article>
        ))}
      </div>
      <div class="center-actions">
        <a class="button button-primary" href={dossierPath} data-analytics-event="site.cta_click" data-analytics-cta-id="view_full_dossier" data-analytics-placement="work_preview">{copy.workPreview.cta}</a>
      </div>
    </section>

    <section class="download-band">
      <div class="section-shell download-layout">
        <div data-reveal>
          <h2>{copy.downloadBand.title}</h2>
          <p>{copy.downloadBand.body}</p>
        </div>
        <div class="download-actions">
          <a class="download-link" href={download.href} target="_blank" rel="noreferrer" data-reveal data-analytics-event="site.asset_download" data-analytics-asset-id={locale === "fr" ? "dossier_fr_pdf" : "dossier_en_pdf"} data-analytics-placement="download_band">
            <strong>{download.label}</strong>
            <span>{download.meta}</span>
          </a>
        </div>
      </div>
    </section>

    <section class="section-shell blog-preview" aria-labelledby="blog-preview-title">
      <div class="section-heading" data-reveal>
        <h2 id="blog-preview-title">{copy.blogPreview.title}</h2>
        <p>{copy.blogPreview.body}</p>
      </div>
      <div class="article-grid article-grid-preview">
        {articleCards.map((article, index) => (
          <a class="article-card" href={article.href} data-reveal style={`--i: ${index}`} data-analytics-event="site.article_open" data-analytics-article-id={article.slug} data-analytics-placement="blog_preview">
            {article.heroImage && (
              <img src={article.heroImage} alt="" loading="lazy" decoding="async" />
            )}
            <span>{article.label}</span>
            <h3>{article.title}</h3>
            <p>{article.excerpt}</p>
            <small>{article.date} · {article.readTime}</small>
          </a>
        ))}
      </div>
      <div class="center-actions">
        <a class="button button-secondary" href={blogPath} data-analytics-event="site.cta_click" data-analytics-cta-id="read_blog" data-analytics-placement="blog_preview">{copy.blogPreview.cta}</a>
      </div>
    </section>
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
