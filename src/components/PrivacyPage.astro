---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "./SiteFooter.astro";
import Topbar from "./Topbar.astro";
import type { Locale } from "../data/site";

type Props = { locale?: Locale };
const { locale = "fr" } = Astro.props;
const pagePath = locale === "fr" ? "/privacy/" : "/en/privacy/";
const copy = locale === "fr"
  ? {
      title: "Confidentialité et mesure de performance",
      description: "Notice sur les préférences fonctionnelles et la mesure de fiabilité optionnelle du site.",
      intro: "Ce site est statique. Il ne crée aucun compte utilisateur et n’envoie aucune identité nominative à un service d’analytics.",
      functionalTitle: "Préférences fonctionnelles",
      functional: "Le thème et la langue peuvent être conservés dans le stockage local du navigateur. Ces choix servent uniquement au fonctionnement et à l’affichage du site.",
      rumTitle: "Mesure optionnelle de performance et de fiabilité",
      rum: "Après votre accord explicite, le site peut charger HyperDX Browser pour mesurer les Web Vitals, les chargements de document, les tâches longues et des catégories d’erreurs techniques minimisées.",
      excluded: "La session n’est pas rejouée et les corps OTLP ne sont pas journalisés par l’ingress. Le SDK peut inclure transitoirement une URL complète, le user-agent, la taille d’écran ou des événements techniques dans la requête first-party. Le collector supprime ces champs avant stockage dans ClickStack. La console, les champs, le texte du DOM, les corps et en-têtes réseau applicatifs, les messages et piles d’erreur et l’identité utilisateur ne sont jamais conservés.",
      analyticsTitle: "Analytics produit optionnels",
      analytics: "Après un accord séparé, le site peut charger PostHog depuis son infrastructure Cloud EU. Les événements couvrent les pages consultées, les CTA, les téléchargements, les sorties vers des plateformes connues, les changements de langue et les seuils de lecture à 50 et 90 %.",
      analyticsExcluded: "L’autocapture, les replays, les heatmaps, les Web Vitals PostHog, les feature flags, les profils personnels et les URL complètes sont désactivés. Les recherches ne transmettent jamais le texte saisi : seuls un type de commande fermé, une tranche de longueur et le nombre de résultats sont admis.",
      analyticsRetention: "PostHog jette l’adresse IP après les transformations techniques nécessaires. La politique cible est une conservation maximale d’un an, mais ce plafond n’est pas encore vérifié comme une règle techniquement appliquée par le projet PostHog. L’identifiant aléatoire reste propre à ce domaine et n’est jamais relié à un email ou à une identité commerciale.",
      analyticsLimits: "Ces événements décrivent une intention de navigation, pas un résultat commercial. Un clic vers une page de réservation n’est jamais compté comme un lead ni comme un rendez-vous confirmé. Les paramètres de campagne donnent un indice d’attribution ; ils ne prouvent pas qu’une campagne a causé une conversion.",
      cookieTitle: "Session et conservation",
      cookie: "Le cookie first-party __rum_sid expire après 15 minutes d’inactivité et une session dure au maximum 4 heures. Si le stockage local est indisponible pendant un retrait, un cookie de préférence __rum_optout peut conserver le refus pendant un an. Les traces et sessions sont conservées 30 jours dans une instance ClickStack privée administrée par Amine Amanzou.",
      withdrawalTitle: "Refus et retrait",
      withdrawal: "Vous pouvez refuser chaque finalité sans perte de fonctionnalité. Les contrôles Confidentialité et Analytics restent accessibles en bas de page. Un retrait enregistre le refus, efface le stockage du SDK concerné et recharge la page sans relancer la collecte.",
      deletionTitle: "Suppression des données",
      deletion: "Le retrait arrête les nouvelles mesures et efface les données du SDK dans ce navigateur. Pour demander la suppression d’événements déjà transmis, écrivez à admin@itart.studio en indiquant le site, une période approximative et, si vous le connaissez, l’identifiant technique aléatoire. Aucune identité nominative n’étant collectée, une demande sans identifiant ni période peut ne pas permettre d’isoler les événements concernés. Le traitement et la vérification de la suppression sont confirmés au demandeur lorsque les événements peuvent être isolés.",
      analyticsSettings: "Gérer les analytics",
    }
  : {
      title: "Privacy and performance measurement",
      description: "Notice covering functional preferences and optional website reliability measurement.",
      intro: "This is a static website. It creates no user account and sends no named identity to an analytics service.",
      functionalTitle: "Functional preferences",
      functional: "Theme and language may be stored locally in the browser. These choices are used only to operate and display the website.",
      rumTitle: "Optional performance and reliability measurement",
      rum: "After your explicit consent, the website may load HyperDX Browser to measure Web Vitals, document loads, long tasks and privacy-minimised technical error categories.",
      excluded: "Sessions are not replayed and the ingress does not log OTLP bodies. The SDK may transiently include a complete URL, user-agent, screen size or technical events in the first-party request. The collector removes these fields before ClickStack storage. Console output, fields, DOM text, application network bodies and headers, error messages and stacks and user identity are never retained.",
      analyticsTitle: "Optional product analytics",
      analytics: "After separate consent, the website may load PostHog from its EU Cloud infrastructure. Events cover page views, CTAs, downloads, outbound links to known platforms, locale changes and 50/90 percent reading thresholds.",
      analyticsExcluded: "Autocapture, replays, heatmaps, PostHog Web Vitals, feature flags, personal profiles and complete URLs are disabled. Search text is never transmitted: only a closed command type, a length bucket and the number of results are accepted.",
      analyticsRetention: "PostHog discards the IP address after the technical transformations required for ingestion. The policy target is a maximum one-year retention period, but this limit has not yet been verified as a technically enforced rule in the PostHog project. The random identifier remains specific to this domain and is never linked to an email or commercial identity.",
      analyticsLimits: "These events describe navigation intent, not a commercial outcome. A click through to a booking page is never counted as a lead or a confirmed meeting. Campaign parameters provide attribution evidence; they do not prove that a campaign caused a conversion.",
      cookieTitle: "Session and retention",
      cookie: "The first-party __rum_sid cookie expires after 15 minutes of inactivity and a session lasts no more than 4 hours. If local storage is unavailable during withdrawal, an __rum_optout preference cookie may retain the opt-out for one year. Traces and sessions are retained for 30 days in a private ClickStack instance administered by Amine Amanzou.",
      withdrawalTitle: "Refusal and withdrawal",
      withdrawal: "You may refuse either purpose without losing functionality. The Privacy and Analytics controls remain available at the bottom of the page. Withdrawal records the refusal, clears the relevant SDK storage and reloads without restarting collection.",
      deletionTitle: "Data deletion",
      deletion: "Withdrawal stops new measurement and clears SDK data in this browser. To request deletion of events already sent, email admin@itart.studio with the site, an approximate time range and, if known, the random technical identifier. Because no named identity is collected, a request without an identifier or time range may not allow the relevant events to be isolated. Processing and verification of deletion are confirmed to the requester when the events can be isolated.",
      analyticsSettings: "Manage analytics",
    };
---

<BaseLayout
  title={`${copy.title} · Amine Amanzou`}
  description={copy.description}
  canonicalPath={pagePath}
  alternates={[{ locale: "fr", path: "/privacy/" }, { locale: "en", path: "/en/privacy/" }]}
  bodyClass="privacy-page"
  locale={locale}
>
  <Topbar currentPath={pagePath} locale={locale} />
  <main class="page-main">
    <article class="article-shell article-content privacy-content">
      <h1>{copy.title}</h1>
      <p>{copy.intro}</p>
      <h2>{copy.functionalTitle}</h2>
      <p>{copy.functional}</p>
      <h2>{copy.rumTitle}</h2>
      <p>{copy.rum}</p>
      <p>{copy.excluded}</p>
      <h2>{copy.analyticsTitle}</h2>
      <p>{copy.analytics}</p>
      <p>{copy.analyticsExcluded}</p>
      <p>{copy.analyticsRetention}</p>
      <p>{copy.analyticsLimits}</p>
      <h2>{copy.cookieTitle}</h2>
      <p>{copy.cookie}</p>
      <h2>{copy.withdrawalTitle}</h2>
      <p>{copy.withdrawal}</p>
      <h2>{copy.deletionTitle}</h2>
      <p>{copy.deletion}</p>
      <p><button class="button button-secondary" type="button" data-open-analytics-settings>{copy.analyticsSettings}</button></p>
    </article>
  </main>
  <SiteFooter locale={locale} />
</BaseLayout>
