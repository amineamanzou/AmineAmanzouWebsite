---
import { profile, type Locale } from "../data/site";

const featuredLinks = profile.links.filter((link) => ["LinkedIn", "GitHub"].includes(link.label));

type Props = {
  locale?: Locale;
};

const { locale = "fr" } = Astro.props;
---

<footer class="site-footer">
  <div>
    <strong>{profile.name}</strong>
    <span>{locale === "fr" ? profile.role : profile.roleEn}</span>
  </div>
  <nav aria-label={locale === "fr" ? "Liens sociaux" : "Social links"}>
    <a href={locale === "fr" ? "/privacy/" : "/en/privacy/"}>
      {locale === "fr" ? "Confidentialité" : "Privacy"}
    </a>
    {featuredLinks.map((link) => (
      <a href={link.href} target="_blank" rel="noreferrer" data-analytics-event="site.outbound_click" data-analytics-destination={link.label.toLowerCase()} data-analytics-placement="footer">{link.label}</a>
    ))}
  </nav>
</footer>
